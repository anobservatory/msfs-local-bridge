<Window
    x:Class="BridgeAssistant.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="MSFS Bridge Assistant"
    Height="900"
    Width="1440">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" RowDefinitions="Auto,*,Auto">
        <InfoBar
            Grid.Row="0"
            IsOpen="True"
            IsClosable="False"
            Severity="Informational"
            Title="Window Frame Constraint"
            Message="Native titlebar and caption buttons follow WinUI framework behavior, not exact HTML mockup pixels." />

        <NavigationView
            x:Name="AppNav"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            PaneDisplayMode="Left"
            PaneTitle="MSFS Bridge Assistant"
            SelectionChanged="OnNavigationSelectionChanged">

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Dashboard" Icon="Home" Tag="dashboard" />
                <NavigationViewItem Content="Setup Wizard" Icon="Page" Tag="wizard" />
                <NavigationViewItem Content="Preflight Checks" Icon="Accept" Tag="preflight" />
                <NavigationViewItem Content="Certificate Manager" Icon="Secure" Tag="certs" />
                <NavigationViewItem Content="Bridge Runtime" Icon="Play" Tag="runtime" />
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="Settings" Icon="Setting" Tag="settings" />
            </NavigationView.FooterMenuItems>

            <Frame x:Name="ContentFrame" />
        </NavigationView>

        <Grid
            Grid.Row="2"
            Padding="12,6"
            BorderThickness="0,1,0,0"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto,Auto">
            <FontIcon x:Name="StatusDot" Glyph="&#xE73E;" FontSize="12" Foreground="#9AA0A6" VerticalAlignment="Center" />
            <TextBlock x:Name="StatusBridgeText" Grid.Column="1" Margin="6,0,0,0" Text="Bridge: Idle" VerticalAlignment="Center" />
            <TextBlock Grid.Column="2" Margin="10,0,0,0" Text="|" Opacity="0.5" VerticalAlignment="Center" />
            <TextBlock x:Name="StatusSimconnectText" Grid.Column="3" Margin="10,0,0,0" Text="SimConnect: Waiting" VerticalAlignment="Center" />

            <TextBlock x:Name="StatusIssuesText" Grid.Column="5" Text="Issues: unknown" VerticalAlignment="Center" />
            <TextBlock Grid.Column="6" Margin="10,0,0,0" Text="|" Opacity="0.5" VerticalAlignment="Center" />
            <TextBlock x:Name="StatusModeText" Grid.Column="7" Margin="10,0,0,0" Text="WSS mode: auto" VerticalAlignment="Center" />
        </Grid>
    </Grid>
</Window>
