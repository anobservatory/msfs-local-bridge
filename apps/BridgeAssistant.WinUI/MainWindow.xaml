<Window
    x:Class="BridgeAssistant.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="MSFS Bridge Assistant"
    Height="880"
    Width="1420">

    <Grid RowDefinitions="Auto,*,Auto">
        <Border Grid.Row="0" Background="#1E1E1E" Padding="12,8" BorderBrush="#303030" BorderThickness="0,0,0,1">
            <TextBlock
                Text="Native titlebar/caption behavior follows WinUI framework rules (not exact HTML pixel match)."
                Foreground="#D0D0D0"
                FontSize="12" />
        </Border>

        <NavigationView
            x:Name="AppNav"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            PaneDisplayMode="Left"
            PaneTitle="MSFS Bridge Assistant"
            SelectionChanged="OnNavigationSelectionChanged">

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Dashboard" Icon="Home" Tag="dashboard" />
                <NavigationViewItem Content="Setup Wizard" Icon="Page" Tag="wizard" />
                <NavigationViewItem Content="Preflight Checks" Icon="Accept" Tag="preflight" />
                <NavigationViewItem Content="Certificate Manager" Icon="Secure" Tag="certs" />
                <NavigationViewItem Content="Bridge Runtime" Icon="Play" Tag="runtime" />
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="Settings" Icon="Setting" Tag="settings" />
            </NavigationView.FooterMenuItems>

            <Frame x:Name="ContentFrame" />
        </NavigationView>

        <Grid Grid.Row="2" Background="#202020" Padding="12,4" ColumnDefinitions="Auto,Auto,Auto,*,Auto">
            <TextBlock x:Name="StatusBridgeText" Text="Bridge: Idle" Foreground="#D0D0D0" />
            <TextBlock Grid.Column="1" Margin="10,0,0,0" Text="|" Foreground="#6D6D6D" />
            <TextBlock Grid.Column="2" x:Name="StatusIssuesText" Margin="10,0,0,0" Text="Issues: unknown" Foreground="#D0D0D0" />
            <TextBlock Grid.Column="4" x:Name="StatusModeText" Text="WSS mode: auto" Foreground="#D0D0D0" />
        </Grid>
    </Grid>
</Window>
