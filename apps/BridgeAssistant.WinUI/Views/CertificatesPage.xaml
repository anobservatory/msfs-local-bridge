<Page
    x:Class="BridgeAssistant.WinUI.Views.CertificatesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Spacing="14" Padding="24">
        <TextBlock Text="Certificate Manager" FontSize="28" FontWeight="SemiBold" />

        <Border BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="6" Padding="12">
            <StackPanel Spacing="8">
                <TextBlock Text="Prerequisite" FontWeight="SemiBold" />
                <TextBlock x:Name="MkcertStatusText" Text="mkcert check: run diagnostics" Foreground="#C0C0C0" />
            </StackPanel>
        </Border>

        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button x:Name="GenerateButton" Content="Generate + Install" Click="OnGenerateClick" />
            <Button x:Name="VerifyButton" Content="Verify Trust" Click="OnVerifyClick" />
            <Button x:Name="RefreshButton" Content="Re-run Diagnostics" Click="OnRefreshDiagnosticsClick" />
        </StackPanel>

        <TextBlock x:Name="ResultText" Text="No action yet." Foreground="#C0C0C0" TextWrapping="Wrap" />
    </StackPanel>
</Page>
