<Page
    x:Class="BridgeAssistant.WinUI.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Spacing="16" Padding="24">
            <TextBlock Text="Dashboard" FontSize="28" FontWeight="SemiBold" />

            <InfoBar
                x:Name="AdminInfoBar"
                IsOpen="True"
                IsClosable="False"
                Severity="Warning"
                Title="Administrator approval required"
                Message="Firewall and trust-store changes must run in Administrator PowerShell with UAC confirmation." />

            <InfoBar
                x:Name="CertInfoBar"
                IsOpen="True"
                IsClosable="False"
                Severity="Informational"
                Title="WSS certificate not ready"
                Message="Expected on first run. Open Certificate Manager, then run diagnostics again." />

            <TextBlock Text="System Health" FontSize="14" FontWeight="SemiBold" Opacity="0.8" />
            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="10">
                <Border Grid.Column="0" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Passed" Opacity="0.7" />
                        <TextBlock x:Name="PassCountText" Text="0" FontSize="24" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Warnings" Opacity="0.7" />
                        <TextBlock x:Name="WarnCountText" Text="0" FontSize="24" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Failures" Opacity="0.7" />
                        <TextBlock x:Name="FailCountText" Text="0" FontSize="24" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Bridge Status" Opacity="0.7" />
                        <TextBlock x:Name="BridgeStatusText" Text="Idle" FontSize="24" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </Grid>

            <TextBlock Text="Connection Endpoints" FontSize="14" FontWeight="SemiBold" Opacity="0.8" />
            <Border BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Padding="12">
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="8" ColumnDefinitions="120,*,Auto" ColumnSpacing="8">
                    <TextBlock Text="WS" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <TextBox Grid.Column="1" x:Name="WsEndpointBox" IsReadOnly="True" />
                    <Button Grid.Column="2" Content="Copy" Click="OnCopyWsClick" />

                    <TextBlock Grid.Row="1" Text="WSS" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="WssEndpointBox" IsReadOnly="True" />
                    <Button Grid.Row="1" Grid.Column="2" Content="Copy" Click="OnCopyWssClick" />

                    <TextBlock Grid.Row="2" Text="BTR" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="BootstrapEndpointBox" IsReadOnly="True" />
                    <Button Grid.Row="2" Grid.Column="2" Content="Copy" Click="OnCopyBootstrapClick" />
                </Grid>
            </Border>

            <TextBlock Text="Quick Actions" FontSize="14" FontWeight="SemiBold" Opacity="0.8" />
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                <Button x:Name="StartBridgeButton" Content="Start Bridge" Click="OnStartBridgeClick" />
                <Button Grid.Column="1" Content="Run Diagnostics" Click="OnRunDiagnosticsClick" />
                <Button Grid.Row="1" Content="Setup Certificates" Click="OnOpenCertificatesClick" />
                <Button Grid.Row="1" Grid.Column="1" Content="Prepare Firewall Command" Click="OnOpenPreflightForFirewallClick" />
            </Grid>

            <TextBlock x:Name="StartNoteText" Text="If WSS mode is Required, Start stays blocked until certificate and key checks pass." Opacity="0.75" TextWrapping="Wrap" />

            <TextBlock Text="Open Issues" FontSize="14" FontWeight="SemiBold" Opacity="0.8" />
            <ListView x:Name="IssuesList" MinHeight="96" MaxHeight="180" />

            <TextBlock Text="Recent Activity" FontSize="14" FontWeight="SemiBold" Opacity="0.8" />
            <ListView x:Name="RecentLogList" MinHeight="120" MaxHeight="220" />
        </StackPanel>
    </ScrollViewer>
</Page>
