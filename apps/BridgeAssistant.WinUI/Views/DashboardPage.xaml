<Page
    x:Class="BridgeAssistant.WinUI.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Spacing="16" Padding="24">
            <TextBlock Text="Dashboard" FontSize="28" FontWeight="SemiBold" />

            <InfoBar
                IsOpen="True"
                IsClosable="False"
                Severity="Informational"
                Title="Implementable constraints"
                Message="Firewall and certificate trust operations remain admin-approved command flows." />

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="RunDiagnosticsButton" Content="Run Diagnostics" Click="OnRunDiagnosticsClick" />
                <Button x:Name="StartBridgeButton" Content="Start Bridge" Click="OnStartBridgeClick" />
                <Button Content="Open Certificate Manager" Click="OnOpenCertificatesClick" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <ProgressRing x:Name="BusyRing" Width="18" Height="18" IsActive="False" />
                <TextBlock x:Name="SummaryText" Text="Run diagnostics to collect current checks." Foreground="#C0C0C0" />
            </StackPanel>

            <Border BorderThickness="1" BorderBrush="#3A3A3A" CornerRadius="6" Padding="12">
                <StackPanel Spacing="8">
                    <TextBlock Text="Open issues" FontWeight="SemiBold" />
                    <ListView x:Name="IssuesList" MinHeight="120" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
