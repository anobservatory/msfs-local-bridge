<Page
    x:Class="BridgeAssistant.WinUI.Views.PreflightPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" RowDefinitions="Auto,Auto,Auto,*,Auto,Auto" RowSpacing="12">
        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
            <TextBlock Text="Preflight Checks" FontSize="28" FontWeight="SemiBold" VerticalAlignment="Center" />
            <Button Grid.Column="1" x:Name="RunDiagnosticsButton" Content="Run Diagnostics" Click="OnRunDiagnosticsClick" />
            <Button Grid.Column="2" Content="Select Firewall Item" Click="OnSelectFirewallClick" />
        </Grid>

        <Border Grid.Row="1" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Padding="12">
            <TextBlock
                Text="Auto-fix covers non-elevated tasks only. For firewall and trust-store changes, copy command, run in Administrator PowerShell, then re-run diagnostics."
                TextWrapping="Wrap"
                Opacity="0.8" />
        </Border>

        <TextBlock Grid.Row="2" x:Name="SummaryText" Text="Run diagnostics to load preflight checks." Opacity="0.75" />

        <ListView x:Name="ChecksList" Grid.Row="3" SelectionChanged="OnCheckSelectionChanged">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="220,*,Auto" ColumnSpacing="10" Padding="6,4">
                        <TextBlock Text="{Binding Id}" Opacity="0.65" TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="1" Text="{Binding Label}" TextWrapping="Wrap" />
                        <TextBlock Grid.Column="2" Text="{Binding StatusText}" Opacity="0.75" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock Grid.Row="4" Text="Repair Command (Admin when noted)" FontWeight="SemiBold" />

        <Grid Grid.Row="5" ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBox
                x:Name="RepairCommandBox"
                IsReadOnly="True"
                TextWrapping="Wrap"
                AcceptsReturn="True"
                VerticalScrollBarVisibility="Auto"
                MinHeight="92"
                MaxHeight="180" />
            <StackPanel Grid.Column="1" Spacing="8" VerticalAlignment="Top">
                <Button Content="Copy" Click="OnCopyCommandClick" />
                <Button Content="Re-run Diagnostics" Click="OnRerunDiagnosticsClick" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
