<Page
    x:Class="BridgeAssistant.WinUI.Views.RuntimePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" RowDefinitions="Auto,Auto,Auto,Auto,*,Auto" RowSpacing="12">
        <TextBlock Text="Bridge Runtime" FontSize="28" FontWeight="SemiBold" />

        <Border Grid.Row="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="12">
            <StackPanel Spacing="10">
                <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="8">
                    <TextBlock x:Name="RuntimeStateText" Text="Idle" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" />
                    <Button x:Name="StartButton" Grid.Column="2" Content="Start" Click="OnStartClick" />
                    <Button x:Name="StopButton" Grid.Column="3" Content="Stop" Click="OnStopClick" />
                    <Button x:Name="RestartButton" Grid.Column="4" Content="Restart" Click="OnRestartClick" />
                </Grid>

                <TextBlock x:Name="StartReasonText" Text="Start is available with current settings." Opacity="0.8" TextWrapping="Wrap" />

                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="80,*" RowSpacing="6" ColumnSpacing="8">
                    <TextBlock Text="WS" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" x:Name="WsEndpointText" TextWrapping="Wrap" Opacity="0.8" />

                    <TextBlock Grid.Row="1" Text="WSS" FontWeight="SemiBold" />
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="WssEndpointText" TextWrapping="Wrap" Opacity="0.8" />
                </Grid>

                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                    <StackPanel>
                        <TextBlock Text="WSS mode" Opacity="0.65" />
                        <TextBlock x:Name="WssModeText" Text="Auto" FontWeight="SemiBold" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Active connections" Opacity="0.65" />
                        <TextBlock x:Name="ConnectionText" Text="0" FontWeight="SemiBold" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Uptime" Opacity="0.65" />
                        <TextBlock x:Name="UptimeText" Text="-" FontWeight="SemiBold" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="2" Text="Live Log" FontSize="14" FontWeight="SemiBold" Opacity="0.8" />

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Content="Clear log" Click="OnClearLogClick" />
            <Button Content="Re-run Diagnostics" Click="OnRerunDiagnosticsClick" />
        </StackPanel>

        <TextBox
            Grid.Row="4"
            x:Name="RuntimeLogBox"
            IsReadOnly="True"
            TextWrapping="Wrap"
            AcceptsReturn="True"
            VerticalScrollBarVisibility="Auto"
            FontFamily="Consolas"
            MinHeight="220" />

        <TextBlock Grid.Row="5" x:Name="HintText" Text="Bridge not running. Press Start to launch." Opacity="0.75" />
    </Grid>
</Page>
