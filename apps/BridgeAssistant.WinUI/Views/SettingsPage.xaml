<Page
    x:Class="BridgeAssistant.WinUI.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Spacing="14" Padding="24">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                <TextBlock Text="Settings" FontSize="28" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Reset defaults" Click="OnResetDefaultsClick" />
                <Button Grid.Column="2" Content="Save changes" Click="OnSaveClick" />
            </Grid>

            <TextBlock Text="Network" FontSize="14" FontWeight="SemiBold" Opacity="0.8" />
            <Border BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Padding="12">
                <Grid ColumnDefinitions="220,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="8">
                    <TextBlock Text="Bind address (-BindHost)" VerticalAlignment="Center" />
                    <TextBox Grid.Column="1" x:Name="BindHostBox" />

                    <TextBlock Grid.Row="1" Text="WS port (-Port)" VerticalAlignment="Center" />
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="WsPortBox" />

                    <TextBlock Grid.Row="2" Text="WSS port (-WssPort)" VerticalAlignment="Center" />
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="WssPortBox" />

                    <TextBlock Grid.Row="3" Text="WSS domain (-LocalDomain)" VerticalAlignment="Center" />
                    <TextBox Grid.Row="3" Grid.Column="1" x:Name="DomainBox" />
                </Grid>
            </Border>

            <TextBlock Text="WSS Mode" FontSize="14" FontWeight="SemiBold" Opacity="0.8" />
            <Border BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Padding="12">
                <StackPanel Spacing="8">
                    <TextBlock Text="Auto: default fallback. Disabled: -DisableWss. Required: -RequireWss." TextWrapping="Wrap" Opacity="0.75" />
                    <ComboBox x:Name="WssModeBox" Width="220" HorizontalAlignment="Left">
                        <x:String>Auto</x:String>
                        <x:String>Disabled</x:String>
                        <x:String>Required</x:String>
                    </ComboBox>
                </StackPanel>
            </Border>

            <CheckBox x:Name="AdvancedToggle" Content="Advanced tuning (optional)" Checked="OnAdvancedToggleChanged" Unchecked="OnAdvancedToggleChanged" />

            <StackPanel x:Name="AdvancedPanel" Visibility="Collapsed" Spacing="14">
                <TextBlock Text="Performance" FontSize="14" FontWeight="SemiBold" Opacity="0.8" />
                <Border BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Padding="12">
                    <Grid ColumnDefinitions="220,*" RowDefinitions="Auto,Auto" RowSpacing="8" ColumnSpacing="8">
                        <TextBlock Text="Sample interval (-SampleIntervalMs)" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" x:Name="SampleMsBox" />

                        <TextBlock Grid.Row="1" Text="Poll interval (-PollIntervalMs)" VerticalAlignment="Center" />
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="PollMsBox" />
                    </Grid>
                </Border>

                <TextBlock Text="Reconnect" FontSize="14" FontWeight="SemiBold" Opacity="0.8" />
                <Border BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Padding="12">
                    <Grid ColumnDefinitions="220,*" RowDefinitions="Auto,Auto" RowSpacing="8" ColumnSpacing="8">
                        <TextBlock Text="Initial delay (-ReconnectDelayMs)" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" x:Name="ReconnectMsBox" />

                        <TextBlock Grid.Row="1" Text="Max delay (-ReconnectMaxDelayMs)" VerticalAlignment="Center" />
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="ReconnectMaxMsBox" />
                    </Grid>
                </Border>
            </StackPanel>

            <TextBlock Text="Desktop Frame" FontSize="14" FontWeight="SemiBold" Opacity="0.8" />
            <Border BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Padding="12">
                <TextBlock
                    Text="In the real app, caption buttons and titlebar behavior follow native WinUI rules, not exact HTML mockup pixels."
                    TextWrapping="Wrap"
                    Opacity="0.75" />
            </Border>

            <TextBlock x:Name="ApplyResultText" Text="" Opacity="0.75" TextWrapping="Wrap" />
        </StackPanel>
    </ScrollViewer>
</Page>
