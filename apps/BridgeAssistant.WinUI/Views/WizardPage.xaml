<Page
    x:Class="BridgeAssistant.WinUI.Views.WizardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Spacing="14" Padding="24">
            <TextBlock Text="Setup Wizard" FontSize="28" FontWeight="SemiBold" />
            <TextBlock
                Text="This wizard only runs safe automation. Admin-required steps remain command-guided."
                TextWrapping="Wrap"
                Opacity="0.8" />

            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="12">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBlock Text="Step 1: Run diagnostics" FontWeight="SemiBold" />
                        <TextBlock x:Name="Step1Badge" Grid.Column="1" Text="Pending" Opacity="0.75" />
                    </Grid>
                    <TextBlock Text="Uses diagnostics-v0.ps1 -Format Json as source of truth." Opacity="0.75" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Run Diagnostics" Click="OnRunDiagnosticsClick" />
                        <Button Content="Open Preflight" Click="OnOpenPreflightClick" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="12">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBlock Text="Step 2: Fix firewall warnings (Admin)" FontWeight="SemiBold" />
                        <TextBlock x:Name="Step2Badge" Grid.Column="1" Text="Pending" Opacity="0.75" />
                    </Grid>
                    <TextBlock Text="Run the generated command in Administrator PowerShell and approve UAC." Opacity="0.75" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Open Preflight" Click="OnOpenPreflightClick" />
                        <Button Content="Re-run Diagnostics" Click="OnRunDiagnosticsClick" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="12">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBlock Text="Step 3: Generate certificate" FontWeight="SemiBold" />
                        <TextBlock x:Name="Step3Badge" Grid.Column="1" Text="Pending" Opacity="0.75" />
                    </Grid>
                    <TextBlock Text="Runs setup-wss-cert-v0.ps1. If mkcert is missing, install first and retry." Opacity="0.75" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Open Certificate Manager" Click="OnOpenCertificatesClick" />
                        <Button Content="Re-run Diagnostics" Click="OnRunDiagnosticsClick" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="12">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBlock Text="Step 4: Start bridge" FontWeight="SemiBold" />
                        <TextBlock x:Name="Step4Badge" Grid.Column="1" Text="Pending" Opacity="0.75" />
                    </Grid>
                    <TextBlock x:Name="StartGuideText" Text="Launches start-msfs-sync.ps1 with current settings." Opacity="0.75" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="StartButton" Content="Start Bridge" Click="OnStartBridgeClick" />
                        <Button Content="Open Runtime" Click="OnOpenRuntimeClick" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
