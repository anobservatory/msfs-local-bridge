<Page
    x:Class="BridgeAssistant.WinUI.Views.WizardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Spacing="14" Padding="24">
            <TextBlock Text="Setup Wizard" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Text="Each step maps to existing scripts. Admin-required operations remain user-approved command execution." TextWrapping="Wrap" Foreground="#C0C0C0" />

            <Border BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="6" Padding="12">
                <StackPanel Spacing="8">
                    <TextBlock Text="Step 1: Run diagnostics" FontWeight="SemiBold" />
                    <TextBlock Text="Source of truth: diagnostics-v0.ps1 -Format Json" Foreground="#C0C0C0" />
                </StackPanel>
            </Border>

            <Border BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="6" Padding="12">
                <StackPanel Spacing="8">
                    <TextBlock Text="Step 2: Fix firewall warnings (Admin)" FontWeight="SemiBold" />
                    <TextBlock Text="Run generated command in Administrator PowerShell (UAC approval required)." Foreground="#C0C0C0" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="6" Padding="12">
                <StackPanel Spacing="8">
                    <TextBlock Text="Step 3: Generate certificates" FontWeight="SemiBold" />
                    <TextBlock Text="Prerequisite: mkcert available on PATH." Foreground="#C0C0C0" />
                </StackPanel>
            </Border>

            <Border BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="6" Padding="12">
                <StackPanel Spacing="8">
                    <TextBlock Text="Step 4: Start bridge" FontWeight="SemiBold" />
                    <TextBlock Text="When WSS mode is Required, start remains blocked until certificate checks pass." Foreground="#C0C0C0" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
